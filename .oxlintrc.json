{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "env": { "es2024": true, "node": true },
  "plugins": ["eslint", "typescript", "unicorn", "oxc", "import", "promise"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "error",
    "perf": "error",
    "style": "error",
    "restriction": "error",
    "nursery": "error"
  },
  "options": {
    "reportUnusedDisableDirectives": "deny",
    "denyWarnings": true,
    "typeAware": true,
    "typeCheck": true
  },
  "ignorePatterns": ["node_modules", "dist", "build", ".wrangler", "coverage", "docs"],
  "globals": { "Bun": "readonly" },
  "rules": {
    "import/group-exports": "off",
    "import/consistent-type-specifier-style": "off",
    "import/no-anonymous-default-export": "off",
    "import/no-default-export": "off",
    "import/no-named-export": "off",
    "import/no-nodejs-modules": "off",
    "import/no-namespace": "off",
    "import/no-relative-parent-imports": "off",
    "import/prefer-default-export": "off",
    "import/max-dependencies": "off",
    "import/unambiguous": "off",
    "oxc/no-async-await": "off",
    "typescript/promise-function-async": "off",
    "unicorn/explicit-length-check": "off",
    "unicorn/no-null": "off",
    "unicorn/no-process-exit": "off",
    "no-magic-numbers": ["error", { "ignore": [0, 1, -1, 2, 200, 400, 404, 500, 502] }],
    "no-optional-chaining": "off",
    "no-console": "error",
    "no-debugger": "error",
    "new-cap": [
      "error",
      {
        "capIsNewExceptions": [
          "Any",
          "Array",
          "BigDecimal",
          "BigInt",
          "Boolean",
          "Class",
          "Date",
          "Defect",
          "Effect",
          "ErrorClass",
          "Layer",
          "Literal",
          "Literals",
          "Map",
          "Match",
          "Never",
          "Null",
          "NullishOr",
          "NullOr",
          "Number",
          "NumberFromString",
          "Object",
          "Option",
          "Record",
          "Redacted",
          "Schema",
          "Service",
          "Set",
          "String",
          "Struct",
          "Symbol",
          "TaggedClass",
          "TaggedError",
          "TaggedErrorClass",
          "Tuple",
          "Undefined",
          "UndefinedOr",
          "Union",
          "Unknown",
          "Void"
        ]
      }
    ],
    "arrow-body-style": "off",
    "typescript/explicit-member-accessibility": "off",
    "id-length": "off",
    "init-declarations": "off",
    "max-classes-per-file": ["error", { "max": 10 }],
    "max-params": ["error", { "max": 6 }],
    "max-statements": ["error", { "max": 25 }],
    "no-rest-spread-properties": "off",
    "no-ternary": "off",
    "no-undefined": "off",
    "sort-imports": "off",
    "typescript/array-type": "error",
    "typescript/ban-ts-comment": "error",
    "typescript/consistent-type-definitions": "error",
    "typescript/consistent-type-imports": "error",
    "typescript/dot-notation": "off",
    "typescript/no-deprecated": "error",
    "typescript/explicit-function-return-type": "error",
    "typescript/explicit-module-boundary-types": "error",
    "typescript/no-explicit-any": "error",
    "typescript/no-base-to-string": "error",
    "typescript/no-inferrable-types": "error",
    "typescript/no-non-null-assertion": "error",
    "typescript/no-unsafe-argument": "error",
    "typescript/no-unsafe-assignment": "error",
    "typescript/no-unsafe-call": "error",
    "typescript/no-unsafe-member-access": "error",
    "typescript/no-unsafe-return": "error",
    "typescript/no-unsafe-type-assertion": "error",
    "typescript/parameter-properties": "error",
    "typescript/prefer-readonly": "error",
    "typescript/prefer-readonly-parameter-types": "off",
    "typescript/strict-boolean-expressions": "error",
    "typescript/switch-exhaustiveness-check": "error"
  },
  "overrides": [
    { "files": ["**/*.ts"], "rules": { "no-useless-computed-key": "off" } },
    {
      "files": ["src/config/*.ts", "src/secrets/*.ts"],
      "rules": {
        "new-cap": [
          "error",
          {
            "capIsNewExceptions": [
              "Any",
              "Array",
              "BigDecimal",
              "BigInt",
              "Boolean",
              "Class",
              "Date",
              "Defect",
              "Effect",
              "ErrorClass",
              "Layer",
              "Literal",
              "Literals",
              "Map",
              "Match",
              "Never",
              "Null",
              "NullishOr",
              "NullOr",
              "Number",
              "NumberFromString",
              "Object",
              "Option",
              "Record",
              "Redacted",
              "Schema",
              "Service",
              "Set",
              "String",
              "Struct",
              "Symbol",
              "TaggedClass",
              "TaggedError",
              "TaggedErrorClass",
              "Tuple",
              "Undefined",
              "UndefinedOr",
              "Union",
              "Unknown",
              "Void"
            ]
          }
        ]
      }
    },
    { "files": ["src/cli.ts", "src/cli-*.ts", "src/output.ts"], "rules": { "no-console": "off" } },
    {
      "files": ["**/*.d.ts"],
      "rules": { "typescript/no-empty-interface": "off", "typescript/no-empty-object-type": "off" }
    },
    {
      "files": ["**/*.test.ts"],
      "globals": {
        "afterEach": "readonly",
        "beforeEach": "readonly",
        "Bun": "readonly",
        "describe": "readonly",
        "expect": "readonly",
        "it": "readonly"
      },
      "rules": {
        "no-magic-numbers": "off",
        "no-inline-comments": "off",
        "max-lines": "off",
        "max-lines-per-function": "off",
        "max-statements": "off"
      }
    },
    {
      "files": ["scripts/**/*.ts"],
      "rules": {
        "no-console": "off",
        "no-magic-numbers": "off",
        "no-inline-comments": "off",
        "max-lines": "off",
        "max-lines-per-function": "off",
        "max-statements": "off",
        "typescript/explicit-function-return-type": "off",
        "typescript/explicit-module-boundary-types": "off",
        "typescript/no-unnecessary-condition": "off",
        "typescript/prefer-nullish-coalescing": "off"
      }
    },
    {
      "files": ["src/lib/tty.ts"],
      "rules": {
        "no-magic-numbers": "off",
        "max-lines": "off",
        "max-lines-per-function": "off",
        "no-control-regex": "off",
        "no-inline-comments": "off",
        "sort-keys": "off",
        "unicorn/escape-case": "off",
        "unicorn/no-hex-escape": "off",
        "unicorn/no-nested-ternary": "off",
        "typescript/no-unnecessary-condition": "off",
        "typescript/strict-boolean-expressions": "off"
      }
    }
  ]
}
